PORT=3001
NODE_ENV=development
SERVICE_NAME=auth-service
LOG_LEVEL=debug

# PostgreSQL — uses 'auth' schema inside the shared local instance
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/online_store?schema=auth

# RS256 key pair — generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Then base64 encode: cat private.pem | base64
JWT_PRIVATE_KEY=REPLACE_WITH_BASE64_ENCODED_PRIVATE_KEY
JWT_PUBLIC_KEY=REPLACE_WITH_BASE64_ENCODED_PUBLIC_KEY
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Caching
CACHE_STORE=memory
REDIS_URL=redis://localhost:6379

# Queue
QUEUE_TRANSPORT=rabbitmq
RABBITMQ_URL=amqp://guest:guest@localhost:5672
